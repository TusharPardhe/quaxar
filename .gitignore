# =============================================================================
# quaxar .gitignore
# Comprehensive ignore rules for a Rust XRPL node implementation
# =============================================================================

# =============================================================================
# Rust / Cargo
# =============================================================================

# Compiled output and build artifacts
target/
rust/target/

# Cargo lock is committed for binary projects (keep Cargo.lock tracked)
# But ignore any backup copies
Cargo.lock.bak

# Incremental compilation cache (sometimes outside target/)
*.incremental/

# Rust compiler artifacts
*.rlib
*.rmeta
*.d

# Generated binaries (release artifacts that shouldn't be in source)
*.exe
*.dll
*.so
*.dylib

# Profiling and debugging data from Rust tooling
perf.data
perf.data.old
flamegraph.svg
cargo-timing*.html
cachegrind.out.*
callgrind.out.*
massif.out.*

# cargo-expand output
*.expanded.rs

# =============================================================================
# Operating System Files
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.fseventsd
.AppleDouble
.LSOverride
Icon?

# macOS resource forks and thumbnails
**/Thumbs.db
**/.DS_Store

# Linux
*~
.directory

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
[Dd]esktop.ini

# Windows shortcuts
*.lnk

# =============================================================================
