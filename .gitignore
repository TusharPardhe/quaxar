.cline/
.clinerules

# Tabnine
.tabnine/

# Amazon Q / CodeWhisperer
.aws/amazonq/
.amazonq/

# Augment
.augment/

# Claude
.claude/
CLAUDE.md

# =============================================================================
# Node Runtime Data (XRPL node databases and state)
# =============================================================================

# NuDB database files
*.nudb
db/
data/
/var/lib/xrpld/

# RocksDB database directories
*.sst
*.log.old
MANIFEST-*
CURRENT
LOCK
OPTIONS-*
LOG
LOG.old

# Ledger data and snapshots (large binary files)
*.snapshot
snapshots/

# =============================================================================
# Configuration Files with Secrets
# =============================================================================

# Environment files
.env
.env.*
!.env.example
!.env.template

# Local configuration overrides (may contain credentials)
*.local.cfg
*.local.toml
*.local.yaml
*.local.yml
*.local.json
xrpld.local.cfg

# Secret keys and certificates
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
*.jks
*.keystore
!validators.txt

# Validator token files (sensitive)
validator-token.txt
validator_token.txt
node_identity.txt

# =============================================================================
# Logs and Temporary Files
# =============================================================================

# Log files
*.log
*.log.*
logs/
log/

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
*.patch

# =============================================================================
# Build and Distribution Artifacts
# =============================================================================

# Distribution directories
dist/
out/
build/
pkg/
release/

# Release archives and binaries
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip
*.7z
*.deb
*.rpm
*.msi
*.dmg
*.AppImage

# Operations directory (deployment artifacts)
ops/*
!ops/.gitkeep

# =============================================================================
# Docker
# =============================================================================

# Docker compose override (local customizations)
docker-compose.override.yml
docker-compose.override.yaml

# Docker volumes and data
docker-data/
.docker/

# =============================================================================
# Testing and Coverage
# =============================================================================

# Code coverage output
coverage/
*.gcda
*.gcno
*.gcov
lcov.info
tarpaulin-report.html
cobertura.xml

# Test result files
test-results/
junit.xml
test-output/

# Fuzzing corpus and artifacts
fuzz/corpus/
fuzz/artifacts/
crash-*
leak-*
timeout-*

# Benchmarking output
criterion/
target/criterion/
benchmark-results/

# =============================================================================
# Documentation Build Output
# =============================================================================

# Rust doc output (if generated locally)
target/doc/

# mdBook output
book/

# =============================================================================
# Package Manager and Dependency Caches
# =============================================================================

# npm / node (if any JS tooling is used)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.yarn/

# Python (if any Python scripts are used)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.eggs/

# =============================================================================
# Miscellaneous
# =============================================================================

# Core dumps
core
core.*
vgcore.*

# Valgrind output
valgrind-*.log

# Heap dumps
*.hprof

# Terraform / Infrastructure (if any IaC is added)
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example

# Nix
result
result-*

# Direnv
.envrc

# asdf
.tool-versions

# mise (formerly rtx)
.mise.toml
.mise.*.toml

# Cargo audit database cache
advisory-db/

# sccache
.sccache/

# =============================================================================
# Project-Specific
# =============================================================================

# Load test output
devnet-loadtest.log

# Any generated protocol buffer files (if protobuf is used)
*.pb.go
*_pb2.py
