# =============================================================================

# JetBrains (IntelliJ, CLion, RustRover)
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/
atlassian-ide-plugin.xml

# Visual Studio Code
.vscode/
*.code-workspace
.history/

# Visual Studio
.vs/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vim / Neovim
*.swp
*.swo
*.swn
*.vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
tags
tags.lock
tags.temp

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# Zed
.zed/

# Fleet
.fleet/

# =============================================================================
# AI Coding Agents and Assistants
# =============================================================================

# Kiro
.kiro/

# Cursor
.cursor/
.cursorignore
.cursorindexingignore

# GitHub Copilot
.copilot/

# Windsurf / Codeium
.windsurf/
.codeium/

